# ╔════════════════════════════════════════════════════════════╗
# ║           AbsenBot Environment Configuration                ║
# ║     Copy this file to .env and update the values           ║
# ╚════════════════════════════════════════════════════════════╝

# ========================================
# ENVIRONMENT DETECTION (Optional)
# ========================================
# Force specific environment instead of auto-detect
# Options: termux, windows, vps, linux, macos
# Leave empty for auto-detection (recommended)
# ENVIRONMENT=

# ========================================
# CHROMIUM / CHROME PATH (Optional)
# ========================================
# Override auto-detected Chrome/Chromium path
# Leave empty for auto-detection (recommended)
#
# Windows examples:
#   CHROMIUM_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
#   CHROMIUM_PATH=C:\Program Files (x86)\Google\Chrome\Application\chrome.exe
#
# Linux examples:
#   CHROMIUM_PATH=/usr/bin/chromium-browser
#   CHROMIUM_PATH=/usr/bin/google-chrome
#
# Termux (Android) examples:
#   CHROMIUM_PATH=/data/data/com.termux/files/usr/bin/chromium-browser
#
# macOS examples:
#   CHROMIUM_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
#
# CHROMIUM_PATH=

# ========================================
# PROJECT ROOT (Optional)
# ========================================
# Override project root directory
# Leave empty to use current working directory (recommended)
# PROJECT_ROOT=

# ========================================
# SESSION SETTINGS
# ========================================
# Session timeout in milliseconds
# Default: 86400000 (24 hours)
SESSION_TIMEOUT_MS=86400000

# ========================================
# STARTUP OPTIONS
# ========================================
# Set to 'true' to disable environment info banner on startup
# SILENT_STARTUP=false
