# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Force localhost for development (set to false for production)
FORCE_LOCALHOST=false

# Auth URL - Use domain instead of IP
AUTH_URL=http://monev-absenbot.my.id

# Groq API Key - Get from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Admin Numbers (comma-separated, no spaces)
ADMIN_NUMBERS=628xxxxxxxxxx

# Dashboard Configuration
DASHBOARD_PASSWORD=your_secure_password_here
DASHBOARD_SECRET=random_secret_key_for_sessions
